; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Bridging"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[gui]

theme/custom="res://ui/theme.tres"
theme/default_font_size=20

[rendering]

environment/defaults/default_clear_color=Color(0.078431, 0.113725, 0.168627, 1)

[autoload]

Loc="*res://scripts/localization.gd"
CardDeck="*res://scripts/card_deck.gd"
Round2Data="*res://scripts/round2_data.gd"
Round3Data="*res://scripts/round3_data.gd"
Network="*res://scripts/network.gd"
GameFlow="*res://scripts/game_flow.gd"
