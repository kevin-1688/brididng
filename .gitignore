# Godot 4 editor cache
.godot/

# macOS
.DS_Store

# Auto-generated import artifacts for our hand-parsed data CSVs
# (we read these CSVs manually via FileAccess at runtime, not through
# Godot's resource import system, so these sidecar files are unwanted noise)
data/*.csv.import
data/*.translation

