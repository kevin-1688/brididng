# Godot 4 editor cache
.godot/

# macOS
.DS_Store

# data/*.csv.import files ARE committed on purpose: they pin importer="keep"
# so Godot never re-converts our hand-parsed CSVs into Translation resources
# (which would exclude the raw CSV from exports). Only ignore any stray
# Translation sidecar files that pre-date that fix.
data/*.translation

